extends layout

block content
  .page-header
    h1.page-title Contact Us
    p.page-subtitle Get in touch with our team during business hours
  
  .content-section
    .container
      .row
        .col.contact-info
          h2 Get in Touch
          p We'd love to hear from you! Reach out to us during our business hours and we'll get back to you as soon as possible.
          
          .contact-details
            .contact-item
              .contact-icon 📍
              .contact-text
                h4 Address
                p 123 Business Street
                p Suite 100
                p City, State 12345
            
            .contact-item
              .contact-icon 📞
              .contact-text
                h4 Phone
                p +1 (555) 123-4567
                p Monday - Friday: 9:00 AM - 5:00 PM
            
            .contact-item
              .contact-icon 📧
              .contact-text
                h4 Email
                p info@businesswebsite.com
                p support@businesswebsite.com
            
            .contact-item
              .contact-icon 🕒
              .contact-text
                h4 Business Hours
                p Monday to Friday
                p 9:00 AM - 5:00 PM
                p Closed weekends and holidays
        
        .col.contact-form
          h2 Send us a Message
          .form-container
            form.contact-form(action='#', method='post')
              .form-group
                label(for='name') Full Name *
                input#name(type='text', name='name', required)
              
              .form-group
                label(for='email') Email Address *
                input#email(type='email', name='email', required)
              
              .form-group
                label(for='phone') Phone Number
                input#phone(type='tel', name='phone')
              
              .form-group
                label(for='subject') Subject *
                input#subject(type='text', name='subject', required)
              
              .form-group
                label(for='message') Message *
                textarea#message(name='message', rows='5', required)
              
              .form-group
                button.btn.btn-primary(type='submit') Send Message
              
              .form-note
                p * Required fields
                p We typically respond within 24 hours during business days.
  
  .map-section
    .container
      h2 Find Us
      .map-placeholder
        p 🗺️ Interactive map would be displayed here
        p Visit us at our office during business hours for in-person consultations.
